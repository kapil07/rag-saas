{
  "name": "rag-saas",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm --filter @rag/database generate",
    "db:migrate": "pnpm --filter @rag/database migrate",
    "db:push": "pnpm --filter @rag/database push",
    "db:studio": "pnpm --filter @rag/database studio"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "turbo": "^2.9.10",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
